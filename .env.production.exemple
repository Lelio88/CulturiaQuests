# ============================================================
# CulturiaQuests - Configuration de Production
# ============================================================
# IMPORTANT: Copier ce fichier vers .env.production
# REGENEREZ TOUS les secrets avant de déployer!
# Générer avec: openssl rand -base64 32
# ============================================================

# --- BASE DE DONNEES (Postgres) ---
POSTGRES_DB=strapi
POSTGRES_USER=strapi
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- STRAPI (Backend) ---
HOST=0.0.0.0
PORT=1337
NODE_ENV=production

# Clés de sécurité - A REGENERER IMPERATIVEMENT
# Générer avec: openssl rand -base64 32
APP_KEYS=CHANGE_ME_1==,CHANGE_ME_2==,CHANGE_ME_3==,CHANGE_ME_4==
API_TOKEN_SALT=CHANGE_ME_API_TOKEN_SALT==
ADMIN_JWT_SECRET=CHANGE_ME_ADMIN_JWT_SECRET==
TRANSFER_TOKEN_SALT=CHANGE_ME_TRANSFER_TOKEN_SALT==
JWT_SECRET=CHANGE_ME_JWT_SECRET==
# Clé de chiffrement Strapi v5 (référencée par config/admin.ts -> secrets.encryptionKey)
ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY==

# Ollama (LLM local)
OLLAMA_MODEL=mistral:7b

# --- IA REVIEW (CI UNIQUEMENT — ne PAS définir ici) ---
# OPENAI_API_KEY n'est PAS utilisée par l'application : la génération de quiz et la
# catégorisation POI passent par Ollama (LLM local) ci-dessus. Elle n'est consommée que
# par scripts/ai_reviewer.py dans les workflows GitHub Actions (ai_review.yml, deploy.yml).
# → À définir comme SECRET GitHub Actions, jamais dans ce .env de runtime.
# OPENAI_API_KEY=  (CI-only, voir ci-dessus)
